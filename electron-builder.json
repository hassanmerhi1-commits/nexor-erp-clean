{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.kwanza.erp",
  "productName": "Kwanza ERP",
  "copyright": "Copyright © 2024 Kwanza ERP",
  "directories": {
    "output": "release",
    "buildResources": "build"
  },
  "files": [
    "dist/**/*",
    "electron/**/*",
    "node_modules/**/*",
    "package.json"
  ],
  "asarUnpack": [
    "node_modules/pg/**/*",
    "node_modules/pg-pool/**/*",
    "node_modules/pg-protocol/**/*",
    "node_modules/pg-types/**/*",
    "node_modules/pg-connection-string/**/*",
    "node_modules/pgpass/**/*",
    "node_modules/buffer-writer/**/*",
    "node_modules/packet-reader/**/*"
  ],
  "extraResources": [
    {
      "from": "node_modules",
      "to": "runtime-deps/node_modules",
      "filter": [
        "ws/**/*",
        "pg/**/*",
        "pg-pool/**/*",
        "pg-protocol/**/*",
        "pg-types/**/*",
        "pg-connection-string/**/*",
        "pgpass/**/*",
        "buffer-writer/**/*",
        "packet-reader/**/*",
        "electron-updater/**/*",
        "builder-util-runtime/**/*",
        "lazy-val/**/*",
        "semver/**/*",
        "js-yaml/**/*",
        "argparse/**/*",
        "sax/**/*",
        "lodash.isequal/**/*",
        "fs-extra/**/*",
        "graceful-fs/**/*",
        "jsonfile/**/*",
        "universalify/**/*"
      ]
    },
    {
      "from": "backend",
      "to": "backend",
      "filter": ["**/*", "!node_modules/**/*"]
    },
    {
      "from": "public/splash.png",
      "to": "splash.png"
    },
    {
      "from": "electron/splash.html",
      "to": "splash.html"
    },
    {
      "from": "installer/postgres",
      "to": "postgres",
      "filter": ["postgresql-*-windows-x64.exe"]
    }
  ],
  "publish": {
    "provider": "github",
    "owner": "hassanmerhi1-commits",
    "repo": "angola-invoice-finder-1",
    "releaseType": "release"
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon.ico",
    "artifactName": "KwanzaERP-${version}-${arch}.${ext}"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Kwanza ERP",
    "include": "installer/install-postgres.nsh",
    "perMachine": true,
    "deleteAppDataOnUninstall": false
  },
  "portable": {
    "artifactName": "KwanzaERP-Portable-${version}.${ext}"
  },
  "mac": {
    "target": ["dmg", "zip"],
    "icon": "build/icon.icns",
    "category": "public.app-category.business",
    "artifactName": "KwanzaERP-${version}-${arch}.${ext}"
  },
  "linux": {
    "target": ["AppImage", "deb"],
    "icon": "build/icon.png",
    "category": "Office",
    "artifactName": "KwanzaERP-${version}-${arch}.${ext}"
  }
}
